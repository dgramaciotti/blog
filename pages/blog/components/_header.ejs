<header class="h-14 border-b border-border flex items-center justify-between px-4 shrink-0 bg-white z-20">
    <div class="flex items-center gap-4">
        <button id="mobile-menu-btn" class="p-2 hover:bg-gray-100 rounded-lg lg:hidden">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
        </button>
        <a href="/blog" class="flex items-center gap-2">
            <div class="flex items-center gap-2 bg-black text-white font-bold px-2 py-0.5 rounded text-sm tracking-tight border border-white/20 shadow-sm">
                <img src="/blog/assets/logo.svg" alt="MedFocus" class="w-4 h-4 invert">
                <span>MEDFOCUS</span>
            </div>
        </a>
    </div>
    
    <div class="flex-1 flex justify-end ml-2 sm:ml-6 items-center">
        <%- include('_search') %>
    </div>
</header>
