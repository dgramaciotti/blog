<% if (typeof iframeSrc !== 'undefined' && iframeSrc) { %>
    <div class="article-iframe-wrapper w-full h-[80vh] mb-12">
        <iframe src="<%= iframeSrc %>" class="w-full h-full border-0 rounded-3xl shadow-2xl" loading="lazy"></iframe>
    </div>
<% } %>

<div class="article-body prose prose-slate max-w-none">
    <%- content %>
</div>
